# All recorded test cases
npx playwright test src/tests/recorded/

# Specific test case  ← uses stored session, skips re-login
npx playwright test src/tests/recorded/TC1_SETTINGS_ELEMENTS.spec.ts --project=chromium --no-deps
npx playwright test src/tests/recorded/TC2_CreateSchedulerFlow.spec.ts --project=chromium --no-deps

# Both recorded TCs together (stored session)
npx playwright test src/tests/recorded/TC1_SETTINGS_ELEMENTS.spec.ts src/tests/recorded/TC2_CreateSchedulerFlow.spec.ts --project=chromium --no-deps

# Run + save report zip to reports/ folder in one command
npx playwright test src/tests/recorded/TC1_SETTINGS_ELEMENTS.spec.ts src/tests/recorded/TC2_CreateSchedulerFlow.spec.ts --project=chromium --no-deps && \
  mkdir -p reports && zip -r reports/Settings_standalone_$(date +%Y%m%d_%H%M%S).zip playwright-report/ test-results/

# Run all recorded + save report zip
npx playwright test src/tests/recorded/ --project=chromium --no-deps && \
  mkdir -p reports && zip -r reports/Settings_standalone_$(date +%Y%m%d_%H%M%S).zip playwright-report/ test-results/

# With visible browser
npx playwright test src/tests/recorded/ --headed

# Step-through debugger
PWDEBUG=1 npx playwright test src/tests/recorded/TC2_CreateSchedulerFlow.spec.ts

# No retries (faster debug run)
npx playwright test src/tests/recorded/ --retries=0 --workers=1


npx playwright show-report                        # open at http://localhost:9323
npx playwright show-report --port 9324            # if 9323 is already in use
lsof -ti :9323 | xargs kill -9                    # free port 9323 then retry
npx playwright show-trace test-results/<folder>/trace.zip


python3 manualtestcasedoc/parse_xlsx.py           # Step 1: xlsx → JSON
npx ts-node src/recorded/xlsx_to_spec.ts          # Step 2: JSON → spec files
npx playwright test src/tests/recorded/TC3_*.spec.ts  # Step 3: run new TC


rm playwright/.auth/user.json                     # reset session
npx playwright test --project=setup               # re-authenticate only


npx tsc --noEmit                                  # type-check without compiling

npx playwright codegen \
  --channel chrome \
  --load-storage playwright/.auth/user.json \
  --save-storage playwright/.auth/user.json \
  --ignore-https-errors \
  -o src/tests/recorded/TC_NEW_RECORDED.spec.ts \
  "https://flow.localzoho.com/#/workspace/default/flows"

# Step-through debugger
PWDEBUG=1 npx playwright test src/tests/recorded/TC2_CreateSchedulerFlow.spec.ts

# No retries (faster debug run)
npx playwright test src/tests/recorded/ --retries=0 --workers=1


