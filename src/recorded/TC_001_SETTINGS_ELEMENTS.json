{
  "id": "TC_001",
  "name": "SETTINGS_ELEMENTS",
  "url": "https://flow.localzoho.com/#/settings",
  "description": "Validate the elements present in the settings menu in case of owner",
  "tags": [
    "settings",
    "regression"
  ],
  "steps": [
    {
      "action": "waitForLoadState",
      "state": "networkidle",
      "note": "Page fully loaded"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Settings",
      "note": "Click on the settings menu"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertVisible",
      "role": "heading",
      "name": "GENERAL",
      "note": "Settings menu has GENERAL"
    },
    {
      "action": "assertVisible",
      "role": "heading",
      "name": "FLOW SETUP",
      "note": "Settings menu has FLOW SETUP"
    },
    {
      "action": "assertVisible",
      "role": "heading",
      "name": "MONITORING",
      "note": "Settings menu has MONITORING"
    },
    {
      "action": "assertVisible",
      "role": "heading",
      "name": "AI",
      "note": "Settings menu has AI"
    },
    {
      "action": "assertVisible",
      "role": "heading",
      "name": "SECURITY & COMPLIANCE",
      "note": "Settings menu has SECURITY & COMPLIANCE"
    },
    {
      "action": "click",
      "role": "link",
      "name": "History",
      "note": "Click on the history"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Connections",
      "note": "Click on connection"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertURL",
      "url": "/settings/connections",
      "note": "Connections page should be displayed"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Members",
      "note": "Click on Members"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertURL",
      "url": "/settings/users",
      "note": "Members page should be displayed"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Billing & Usage",
      "note": "Click on publish details"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertURL",
      "url": "/settings/billing",
      "note": "The publish details page should be displayed"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Audit Trail",
      "note": "Click on Audit trail"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertURL",
      "url": "/settings/audit-trail",
      "note": "The audit trail page should be displayed"
    },
    {
      "action": "click",
      "role": "link",
      "name": "Support Access",
      "note": "Click on Support Access"
    },
    {
      "action": "waitForLoadState",
      "state": "networkidle"
    },
    {
      "action": "assertURL",
      "url": "/settings/support",
      "note": "The support Access page should be displayed"
    }
  ]
}